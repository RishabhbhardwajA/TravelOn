<style>
  /* ============================================
     🌊 OCEAN BREEZE NAVBAR - Fresh Blue
     ============================================ */

  /* Vibrant Blue Search Button */
  .btn-search {
    background: linear-gradient(135deg, #3B82F6, #2563EB);
    color: white;
    border-radius: 50px;
    padding: 0.65rem 1.6rem;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    border: none;
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.35);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .btn-search:hover {
    background: linear-gradient(135deg, #60A5FA, #3B82F6);
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(59, 130, 246, 0.5);
  }

  .btn-search i {
    display: inline;
    margin-right: 0.5rem;
  }

  /* Clean White Search Input */
  .search-input {
    background: rgba(255, 255, 255, 0.95) !important;
    border: 2px solid rgba(59, 130, 246, 0.2) !important;
    color: #1E293B !important;
    border-radius: 50px;
    padding: 0.65rem 3rem 0.65rem 1.5rem;
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  .search-input::placeholder {
    color: #94A3B8 !important;
  }

  .search-input:focus {
    border-color: #3B82F6 !important;
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15) !important;
    background: #FFFFFF !important;
  }

  /* Blue User Menu Button */
  .user-menu-btn {
    background: linear-gradient(135deg, #3B82F6, #2563EB);
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.35);
  }

  .user-menu-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 30px rgba(59, 130, 246, 0.5);
    background: linear-gradient(135deg, #60A5FA, #3B82F6);
  }

  .user-menu-btn::after {
    display: none !important;
  }

  /* Fresh White Dropdown Menu */
  .user-dropdown-menu,
  .dropdown-menu.user-dropdown-menu {
    border: none !important;
    border-radius: 16px !important;
    background: rgba(255, 255, 255, 0.98) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border: 1px solid rgba(59, 130, 246, 0.15) !important;
    box-shadow: 0 15px 50px rgba(59, 130, 246, 0.2) !important;
    padding: 0.5rem 0 !important;
    min-width: 220px !important;
    margin-top: 10px !important;
    animation: slideDown 0.2s ease !important;
    overflow: hidden !important;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .user-dropdown-header {
    padding: 1rem 1.2rem;
    background: rgba(11, 29, 42, 0.8);
    border-bottom: 1px solid rgba(77, 163, 255, 0.1);
  }

  .user-dropdown-header .username {
    font-weight: 600;
    color: #1E293B;
    font-size: 1rem;
    margin: 0;
  }

  .user-dropdown-header .email-hint {
    font-size: 0.75rem;
    color: #64748B;
    margin: 0;
  }

  .user-dropdown-menu .dropdown-item {
    padding: 0.8rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    color: #475569;
    transition: all 0.2s ease;
    background: transparent;
  }

  .user-dropdown-menu .dropdown-item:hover {
    background: rgba(59, 130, 246, 0.1);
    color: #3B82F6;
  }

  .user-dropdown-menu .dropdown-item i {
    width: 20px;
    text-align: center;
    font-size: 1rem;
    color: #3B82F6;
  }

  .user-dropdown-menu .dropdown-divider {
    margin: 0.3rem 0;
    border-color: rgba(59, 130, 246, 0.1);
  }

  .user-dropdown-menu .logout-item {
    color: #EF4444;
  }

  .user-dropdown-menu .logout-item:hover {
    background: rgba(239, 68, 68, 0.1);
    color: #DC2626;
  }

  .user-dropdown-menu .dropdown-item {
    padding: 0.8rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    color: #444;
    transition: all 0.2s ease;
    background: transparent;
  }

  .user-dropdown-menu .dropdown-item:hover {
    background: rgba(59, 130, 246, 0.1);
    backdrop-filter: blur(10px);
    color: #3B82F6;
  }

  .user-dropdown-menu .dropdown-item i {
    width: 20px;
    text-align: center;
    font-size: 1rem;
  }

  .user-dropdown-menu .dropdown-divider {
    margin: 0.3rem 0;
    border-color: rgba(59, 130, 246, 0.1);
  }

  .user-dropdown-menu .logout-item {
    color: #EF4444;
  }

  .user-dropdown-menu .logout-item:hover {
    background: rgba(239, 68, 68, 0.1);
    backdrop-filter: blur(10px);
    color: #DC2626;
  }

  /* Dark Mode Support */
  [data-theme="dark"] .user-dropdown-menu {
    background: rgba(40, 40, 60, 0.95) !important;
    backdrop-filter: blur(20px) saturate(180%) !important;
    -webkit-backdrop-filter: blur(20px) saturate(180%) !important;
    border: 1px solid rgba(59, 130, 246, 0.15) !important;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5) !important;
  }

  [data-theme="dark"] .user-dropdown-header {
    background: rgba(50, 50, 70, 0.6);
    border-bottom: 1px solid rgba(59, 130, 246, 0.1);
  }

  [data-theme="dark"] .user-dropdown-header .username {
    color: #ffffff;
  }

  [data-theme="dark"] .user-dropdown-header .email-hint {
    color: #a0a0a0;
  }

  [data-theme="dark"] .user-dropdown-menu .dropdown-item {
    color: #E6EDF3;
  }

  [data-theme="dark"] .user-dropdown-menu .dropdown-item:hover {
    background: rgba(59, 130, 246, 0.15);
    backdrop-filter: blur(10px);
    color: #60A5FA;
  }

  [data-theme="dark"] .user-dropdown-menu .dropdown-divider {
    border-color: rgba(59, 130, 246, 0.1);
  }

  [data-theme="dark"] .user-dropdown-menu .logout-item {
    color: #EF4444;
  }

  [data-theme="dark"] .user-dropdown-menu .logout-item:hover {
    background: rgba(239, 68, 68, 0.15);
    color: #FCA5A5;
  }

  /* Logo 720 degree spin on hover */
  .navbar-brand img {
    transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .navbar-brand:hover img {
    transform: rotate(720deg);
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">

    <!-- Mobile Header (Logo + Search + Toggler) -->
    <div class="d-flex w-100 align-items-center d-md-none">
      <a class="navbar-brand" href="/listings"><img src="/images/logo.png" alt="TravelOn" style="height: 70px;"></a>

      <!-- Mobile Search Bar -->
      <form class="d-flex flex-grow-1 mx-2 align-items-center mobile-search-bar" role="search" action="/listings"
        method="GET" style="min-width: 0;">
        <div class="input-group">
          <input class="form-control shadow-none border-end-0" type="search" placeholder="Search..." name="q"
            style="height: 38px; border-radius: 20px 0 0 20px; font-size: 0.9rem; padding-left: 12px; background: rgba(255,255,255,0.9);">
          <button class="btn border border-start-0" type="submit"
            style="height: 38px; border-radius: 0 20px 20px 0; background: white; border-color: #ced4da;">
            <i class="fa-solid fa-magnifying-glass text-secondary" style="font-size: 0.9rem;"></i>
          </button>
        </div>
      </form>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
        <span class="navbar-toggler-icon"></span>
      </button>
    </div>

    <!-- Desktop Brand (Hidden on mobile) -->
    <a class="navbar-brand d-none d-md-block" href="/listings"><img src="/images/logo.png" alt="TravelOn"
        style="height: 70px;"></a>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <div class="navbar-nav ms-auto">
        <form class="d-none d-md-flex align-items-center" role="search" action="/listings" method="GET">
          <div class="position-relative me-2 flex-grow-1">
            <input class="form-control search-input pe-5" id="desktopSearchInput" type="search"
              placeholder="Search destinations" name="q">
            <button type="button" class="voice-search-btn desktop-voice-btn" id="desktopVoiceBtn"
              title="Search by Voice">
              <i class="fas fa-microphone"></i>
            </button>
          </div>
          <button class="btn btn-search" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>Search
          </button>
        </form>
      </div>

      <div class="navbar-nav ms-auto">
        <!-- Dark Mode Toggle -->
        <a class="nav-link me-3" id="navDarkModeToggle" href="#" title="Toggle Dark Mode">
          <i class="fas fa-moon"></i>
        </a>

        <a class="nav-link" href="/listings/new">New listing</a>

        <% if(typeof currUser==='undefined' || !currUser) { %>
          <a class="nav-link" href="/signup"><b>SignUp</b></a>
          <a class="nav-link" href="/login"><b>Login</b></a>
          <% } %>

            <% if(typeof currUser !=='undefined' && currUser) { %>
              <!-- User Dropdown Menu -->
              <div class="dropdown">
                <button class="user-menu-btn dropdown-toggle" type="button" id="userMenuDropdown"
                  data-bs-toggle="dropdown" aria-expanded="false" title="<%= currUser.username %>">
                  <i class="fas fa-user"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end user-dropdown-menu" aria-labelledby="userMenuDropdown">
                  <li>
                    <div class="user-dropdown-header">
                      <p class="username"><i class="fas fa-circle-user"></i>
                        <%= currUser.username %>
                      </p>
                      <p class="email-hint">Welcome back!</p>
                    </div>
                  </li>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li>
                    <a class="dropdown-item" href="/listings/wishlist">
                      <i class="fas fa-heart" style="color: #fe424d;"></i> My Wishlist
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item" href="/change-password">
                      <i class="fas fa-key" style="color: #ffc107;"></i> Change Password
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item" href="/bookings/my-bookings">
                      <i class="fas fa-calendar-check" style="color: #28a745;"></i> My Bookings
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item" href="/bookings/host-dashboard">
                      <i class="fas fa-home" style="color: #6f42c1;"></i> Host Dashboard
                    </a>
                  </li>

                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li>
                    <a class="dropdown-item logout-item" href="/logout">
                      <i class="fas fa-right-from-bracket"></i> Logout
                    </a>
                  </li>
                </ul>
              </div>
              <% } %>
      </div>

    </div>


  </div>
</nav>
<% layout("layout/boilerplate")%>
<div class="row">
    <div class="col-8 offset-2">
        <h3>Create a new listing</h3>
        <form method="POST" action="/listings" novalidate class="needs-validation">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" name="listing[title]" placeholder="Title" class="form-control" >
                <div class="invalid-feedback">Write a title!</div>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description:</label>
                <textarea name="listing[description]" placeholder="Enter description" class="form-control" ></textarea>
                <div class="invalid-feedback">Write a short description</div>
            </div>
            <div class="row">
                
                <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price:</label>
                <input type="number" id="price" name="listing[price]" placeholder="Enter price" class="form-control" >
            <div class="invalid-feedback">Enter a valid price</div> </div>
                <div class="mb-3 col-md-8">
                <label for="Country" class="form-label" >Country:</label>
                <input type="text" name="listing[country]" placeholder="Enter counrty" class="form-control" >
            <div class="invalid-feedback">Enter a valid counrty</div></div>
                
            </div>
            <div class="mb-3"> 
                <label for="image" class="form-label">Image link:</label>
                <input type="text" placeholder="Enter img url" name="listing[image]" class="form-control" ></div>
            
            <div class="mb-3">
                <label for="loaction" class="form-label">Loaction:</label>
                <input type="text" name="listing[location]" placeholder="Enter location" class="form-control" >
                <div class="invalid-feedback">Enter a valid location</div>
            </div>
            
            <button class="btn btn-dark add-btn">Add</button>
        </form>
</div>
</div>
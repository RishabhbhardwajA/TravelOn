<% layout("layout/boilerplate")%>

    <div class="new-listing-container">
        <div class="new-listing-card">
            <div class="form-header">
                <i class="fas fa-plus-circle header-icon"></i>
                <h2>Create New Listing</h2>
            </div>

            <form method="POST" action="/listings" novalidate class="needs-validation listing-form"
                enctype="multipart/form-data">

                <!-- Title -->
                <div class="form-group">
                    <label for="title"><i class="fas fa-heading"></i> Title</label>
                    <input type="text" name="listing[title]" id="title" placeholder="Give your place a catchy title"
                        class="form-control" required>
                    <div class="invalid-feedback">Please add a title</div>
                </div>

                <!-- Description -->
                <div class="form-group">
                    <label for="description"><i class="fas fa-align-left"></i> Description</label>
                    <textarea name="listing[description]" id="description"
                        placeholder="Describe what makes your place special..." class="form-control" rows="4"
                        required></textarea>
                    <div class="invalid-feedback">Please add a description</div>
                </div>

                <!-- Price & Country Row -->
                <div class="form-row">
                    <div class="form-group half">
                        <label for="price"><i class="fas fa-rupee-sign"></i> Price per night</label>
                        <input type="number" id="price" name="listing[price]" placeholder="₹ 0" class="form-control"
                            required>
                        <div class="invalid-feedback">Enter a valid price</div>
                    </div>
                    <div class="form-group half">
                        <label for="country"><i class="fas fa-globe-asia"></i> Country</label>
                        <input type="text" name="listing[country]" id="country" placeholder="e.g. India"
                            class="form-control" required>
                        <div class="invalid-feedback">Enter country name</div>
                    </div>
                </div>

                <!-- Category - Custom Dropdown -->
                <div class="form-group">
                    <label><i class="fas fa-tags"></i> Category</label>
                    <input type="hidden" name="listing[category]" id="categoryInput" required>
                    <div class="custom-select-wrapper">
                        <div class="custom-select" id="categorySelect">
                            <span class="selected-text">Select a category</span>
                            <i class="fas fa-chevron-down arrow"></i>
                        </div>
                        <div class="custom-options" id="categoryOptions">
                            <% for(let cat of category) { %>
                                <div class="custom-option" data-value="<%= cat %>">
                                    <i class="fas fa-check check-icon"></i>
                                    <%= cat %>
                                </div>
                                <% } %>
                        </div>
                    </div>
                    <div class="invalid-feedback">Please select a category</div>
                </div>

                <!-- Image Upload -->
                <div class="form-group">
                    <label for="image"><i class="fas fa-image"></i> Upload Image</label>
                    <div class="file-upload-wrapper">
                        <input type="file" name="listing[image]" id="image" class="form-control" required
                            accept="image/*">
                    </div>
                    <small class="form-hint">JPG, PNG or WebP (max 5MB)</small>
                </div>

                <!-- Location -->
                <div class="form-group">
                    <label for="location"><i class="fas fa-map-marker-alt"></i> Location</label>
                    <input type="text" name="listing[location]" id="location" placeholder="e.g. Mumbai, Maharashtra"
                        class="form-control" required>
                    <div class="invalid-feedback">Enter location</div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="submit-btn">
                    <i class="fas fa-plus"></i> Create Listing
                </button>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const selectBox = document.getElementById('categorySelect');
            const optionsBox = document.getElementById('categoryOptions');
            const hiddenInput = document.getElementById('categoryInput');
            const selectedText = selectBox.querySelector('.selected-text');
            const options = document.querySelectorAll('.custom-option');

            // Toggle dropdown
            selectBox.addEventListener('click', function (e) {
                e.stopPropagation();
                selectBox.classList.toggle('active');
                optionsBox.classList.toggle('show');
            });

            // Select option
            options.forEach(option => {
                option.addEventListener('click', function () {
                    const value = this.dataset.value;

                    // Update hidden input
                    hiddenInput.value = value;

                    // Update selected text
                    selectedText.textContent = value;
                    selectedText.classList.remove('placeholder');

                    // Update selected state
                    options.forEach(opt => opt.classList.remove('selected'));
                    this.classList.add('selected');

                    // Close dropdown
                    selectBox.classList.remove('active');
                    optionsBox.classList.remove('show');
                });
            });

            // Close on outside click
            document.addEventListener('click', function () {
                selectBox.classList.remove('active');
                optionsBox.classList.remove('show');
            });
        });
    </script>
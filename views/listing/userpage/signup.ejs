<% layout("/layout/boilerplate")%>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <i class="fa-solid fa-user-plus auth-icon"></i>
                <h2>Create Account</h2>
                <p>Join TravelOn and explore the world</p>
            </div>

            <form action="/signup" method="POST" class="needs-validation auth-form" novalidate>
                <div class="form-group">
                    <label for="username"><i class="fa-solid fa-user"></i> Username</label>
                    <input type="text" name="username" id="username" class="form-control auth-input"
                        placeholder="Choose a username" required>
                    <div class="invalid-feedback">Please choose a username</div>
                </div>

                <div class="form-group">
                    <label for="email"><i class="fa-solid fa-envelope"></i> Email</label>
                    <input type="email" name="email" id="email" class="form-control auth-input"
                        placeholder="Enter your email" required>
                    <div class="invalid-feedback">Please enter a valid email</div>
                </div>

                <div class="form-group">
                    <label for="password"><i class="fa-solid fa-lock"></i> Password</label>
                    <input type="password" name="password" id="password" class="form-control auth-input"
                        placeholder="Create a password" required>
                    <div class="invalid-feedback">Please create a password</div>
                </div>

                <button type="submit" class="btn auth-btn">
                    <i class="fa-solid fa-user-plus"></i> Sign Up
                </button>
            </form>

            <div class="auth-footer">
                <p>Already have an account? <a href="/login">Login</a></p>
            </div>
        </div>
    </div>
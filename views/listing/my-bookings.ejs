<% layout("/layout/boilerplate") %>

    <style>
        .my-bookings-page {
            max-width: 900px;
            margin: 2rem auto;
            padding: 0 1.5rem;
            min-height: calc(100vh - 200px);
        }

        .page-header {
            margin-bottom: 2rem;
        }

        .page-header h2 {
            margin: 0 0 0.5rem 0;
            font-size: 1.8rem;
            font-weight: 700;
        }

        .page-header p {
            color: #888;
            margin: 0;
        }

        .booking-tabs {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            background: rgba(0, 0, 0, 0.05);
            padding: 0.5rem;
            border-radius: 12px;
        }

        .tab-btn {
            flex: 1;
            padding: 0.8rem 1rem;
            border: none;
            background: transparent;
            color: #666;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .tab-btn.active {
            background: linear-gradient(135deg, #fe424d, #ff6b6b);
            color: #fff;
            box-shadow: 0 4px 15px rgba(254, 66, 77, 0.3);
        }

        .tab-btn:hover:not(.active) {
            background: rgba(0, 0, 0, 0.08);
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .booking-card {
            display: flex;
            gap: 1.5rem;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            padding: 1.5rem;
            margin-bottom: 1rem;
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s;
        }

        .booking-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
        }

        .booking-card.cancelled {
            opacity: 0.6;
        }

        .booking-card img {
            width: 160px;
            height: 110px;
            object-fit: cover;
            border-radius: 12px;
        }

        .booking-details {
            flex: 1;
        }

        .booking-details h5 {
            margin: 0 0 0.5rem 0;
            color: #333;
            font-size: 1.1rem;
            font-weight: 600;
        }

        .booking-meta {
            color: #666;
            font-size: 0.9rem;
        }

        .booking-meta p {
            margin: 0.4rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .booking-meta i {
            width: 16px;
            color: #fe424d;
        }

        .booking-price {
            font-size: 1.2rem;
            font-weight: 700;
            color: #333;
            margin-top: 0.5rem;
        }

        .booking-actions {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-end;
            gap: 0.75rem;
        }

        .booking-status {
            padding: 0.5rem 1.2rem;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .status-confirmed {
            background: linear-gradient(135deg, #28a745, #20c997);
            color: #fff;
            box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);
        }

        .status-pending {
            background: linear-gradient(135deg, #ffc107, #ffb300);
            color: #333;
        }

        .status-cancelled {
            background: #f8d7da;
            color: #721c24;
        }

        .status-completed {
            background: linear-gradient(135deg, #6c757d, #868e96);
            color: #fff;
        }

        .cancel-btn {
            padding: 0.5rem 1.2rem;
            border: none;
            background: linear-gradient(135deg, #dc3545, #ff6b6b);
            color: #fff;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .cancel-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(220, 53, 69, 0.4);
            opacity: 0.95;
            color: #fff;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            border-radius: 20px;
        }

        .empty-state i {
            font-size: 4rem;
            background: linear-gradient(135deg, #fe424d, #ff6b6b);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
            display: block;
        }

        .empty-state h4 {
            color: #333;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .empty-state p {
            color: #888;
            margin-bottom: 1.5rem;
        }

        .empty-state .btn-primary {
            background: linear-gradient(135deg, #fe424d, #ff6b6b);
            border: none;
            padding: 0.8rem 2rem;
            border-radius: 30px;
            font-weight: 600;
        }

        /* Cancel Confirm Modal */
        .cancel-modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(5px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .cancel-modal-overlay.show {
            display: flex;
        }

        .cancel-modal {
            background: #fff;
            border-radius: 16px;
            padding: 2rem;
            max-width: 400px;
            width: 90%;
            text-align: center;
        }

        .cancel-modal h4 {
            margin: 0 0 0.5rem;
        }

        .cancel-modal p {
            color: #666;
            margin-bottom: 1.5rem;
        }

        .cancel-modal-btns {
            display: flex;
            gap: 1rem;
        }

        .cancel-modal-btns button {
            flex: 1;
            padding: 0.8rem;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            border: none;
        }

        .cancel-modal-btns .keep-btn {
            background: #f0f0f0;
            color: #333;
        }

        .cancel-modal-btns .confirm-cancel-btn {
            background: #dc3545;
            color: #fff;
        }

        @media (max-width: 768px) {
            .booking-card {
                flex-direction: column;
            }

            .booking-card img {
                width: 100%;
                height: 150px;
            }

            .booking-actions {
                flex-direction: row;
                justify-content: space-between;
                width: 100%;
            }
        }
    </style>

    <!-- Cancel Confirmation Modal -->
    <div class="cancel-modal-overlay" id="cancelModal">
        <div class="cancel-modal">
            <h4><i class="fas fa-exclamation-triangle" style="color: #dc3545;"></i> Cancel Booking?</h4>
            <p>Are you sure you want to cancel this booking? This action cannot be undone.</p>
            <div class="cancel-modal-btns">
                <button class="keep-btn" id="keepBookingBtn">Keep Booking</button>
                <button class="confirm-cancel-btn" id="confirmCancelBtn">Yes, Cancel</button>
            </div>
        </div>
    </div>

    <div class="my-bookings-page">
        <div class="page-header">
            <h2><i class="fas fa-calendar-alt" style="color: #fe424d;"></i> My Bookings</h2>
            <p>Manage your travel reservations</p>
        </div>

        <% const now=new Date(); const upcoming=bookings.filter(b=> new Date(b.checkIn) > now && b.status ===
            'confirmed');
            const past = bookings.filter(b => new Date(b.checkOut) < now || b.status==='completed' ); const
                cancelled=bookings.filter(b=> b.status === 'cancelled');
                %>

                <div class="booking-tabs">
                    <button class="tab-btn active" id="upcomingTab">
                        <i class="fas fa-plane"></i> Upcoming (<%= upcoming.length %>)
                    </button>
                    <button class="tab-btn" id="pastTab">
                        <i class="fas fa-history"></i> Past (<%= past.length %>)
                    </button>
                    <button class="tab-btn" id="cancelledTab">
                        <i class="fas fa-times-circle"></i> Cancelled (<%= cancelled.length %>)
                    </button>
                </div>

                <!-- Upcoming Tab -->
                <div id="upcomingContent" class="tab-content active">
                    <% if(upcoming.length===0) { %>
                        <div class="empty-state">
                            <i class="fas fa-suitcase-rolling"></i>
                            <h4>No upcoming trips</h4>
                            <p>Time to plan your next adventure!</p>
                            <a href="/listings" class="btn btn-primary">Explore Listings</a>
                        </div>
                        <% } else { %>
                            <% upcoming.forEach(function(booking) { %>
                                <div class="booking-card">
                                    <img src="<%= booking.listing ? booking.listing.image.url : 'https://via.placeholder.com/160x110' %>"
                                        alt="">
                                    <div class="booking-details">
                                        <h5>
                                            <%= booking.listing ? booking.listing.title : 'Listing unavailable' %>
                                        </h5>
                                        <div class="booking-meta">
                                            <p><i class="fas fa-calendar"></i>
                                                <%= new Date(booking.checkIn).toLocaleDateString("en-IN",
                                                    {day: "numeric" , month: "short" , year: "numeric" }) %>
                                                    → <%= new Date(booking.checkOut).toLocaleDateString("en-IN",
                                                        {day: "numeric" , month: "short" , year: "numeric" }) %>
                                            </p>
                                            <p><i class="fas fa-moon"></i>
                                                <%= booking.nights %> nights
                                            </p>
                                            <p><i class="fas fa-users"></i>
                                                <%= booking.guests.adults + booking.guests.children %> guests
                                            </p>
                                        </div>
                                        <div class="booking-price">₹<%= booking.totalPrice.toLocaleString("en-IN") %>
                                        </div>
                                    </div>
                                    <div class="booking-actions">
                                        <span class="booking-status status-confirmed">
                                            <i class="fas fa-check-circle"></i> Confirmed
                                        </span>
                                        <button class="cancel-btn" data-booking-id="<%= booking._id %>">
                                            <i class="fas fa-times"></i> Cancel
                                        </button>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } %>
                </div>

                <!-- Past Tab -->
                <div id="pastContent" class="tab-content">
                    <% if(past.length===0) { %>
                        <div class="empty-state">
                            <i class="fas fa-history"></i>
                            <h4>No past trips</h4>
                            <p>Your travel history will appear here</p>
                        </div>
                        <% } else { %>
                            <% past.forEach(function(booking) { %>
                                <div class="booking-card">
                                    <img src="<%= booking.listing ? booking.listing.image.url : 'https://via.placeholder.com/160x110' %>"
                                        alt="">
                                    <div class="booking-details">
                                        <h5>
                                            <%= booking.listing ? booking.listing.title : 'Listing unavailable' %>
                                        </h5>
                                        <div class="booking-meta">
                                            <p><i class="fas fa-calendar"></i>
                                                <%= new Date(booking.checkIn).toLocaleDateString("en-IN",
                                                    {day: "numeric" , month: "short" }) %>
                                                    - <%= new Date(booking.checkOut).toLocaleDateString("en-IN",
                                                        {day: "numeric" , month: "short" , year: "numeric" }) %>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="booking-actions">
                                        <span class="booking-status status-completed">
                                            <i class="fas fa-check-double"></i> Completed
                                        </span>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } %>
                </div>

                <!-- Cancelled Tab -->
                <div id="cancelledContent" class="tab-content">
                    <% if(cancelled.length===0) { %>
                        <div class="empty-state">
                            <i class="fas fa-check-circle"></i>
                            <h4>No cancelled bookings</h4>
                            <p>You haven't cancelled any trips</p>
                        </div>
                        <% } else { %>
                            <% cancelled.forEach(function(booking) { %>
                                <div class="booking-card cancelled">
                                    <img src="<%= booking.listing ? booking.listing.image.url : 'https://via.placeholder.com/160x110' %>"
                                        alt="">
                                    <div class="booking-details">
                                        <h5>
                                            <%= booking.listing ? booking.listing.title : 'Listing unavailable' %>
                                        </h5>
                                        <div class="booking-meta">
                                            <p><i class="fas fa-calendar"></i>
                                                <%= new Date(booking.checkIn).toLocaleDateString("en-IN",
                                                    {day: "numeric" , month: "short" }) %>
                                                    - <%= new Date(booking.checkOut).toLocaleDateString("en-IN",
                                                        {day: "numeric" , month: "short" , year: "numeric" }) %>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="booking-actions">
                                        <span class="booking-status status-cancelled">
                                            <i class="fas fa-times"></i> Cancelled
                                        </span>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } %>
                </div>
    </div>

    <script>
        // Tab switching
        var tabs = document.querySelectorAll('.tab-btn');
        var contents = document.querySelectorAll('.tab-content');

        tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                tabs.forEach(function (t) { t.classList.remove('active'); });
                contents.forEach(function (c) { c.classList.remove('active'); });
                tab.classList.add('active');
                document.getElementById(tab.id.replace('Tab', 'Content')).classList.add('active');
            });
        });

        // Cancel booking
        var cancelModal = document.getElementById('cancelModal');
        var pendingCancelId = null;

        document.querySelectorAll('.cancel-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                pendingCancelId = btn.dataset.bookingId;
                cancelModal.classList.add('show');
            });
        });

        document.getElementById('keepBookingBtn').addEventListener('click', function () {
            cancelModal.classList.remove('show');
            pendingCancelId = null;
        });

        document.getElementById('confirmCancelBtn').addEventListener('click', function () {
            if (pendingCancelId) {
                fetch('/bookings/' + pendingCancelId + '/cancel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (data.success) {
                            window.location.reload();
                        } else {
                            alert(data.message || 'Failed to cancel');
                        }
                    })
                    .catch(function () {
                        alert('Error cancelling booking');
                    });
            }
            cancelModal.classList.remove('show');
        });

        cancelModal.addEventListener('click', function (e) {
            if (e.target === cancelModal) {
                cancelModal.classList.remove('show');
            }
        });
    </script>
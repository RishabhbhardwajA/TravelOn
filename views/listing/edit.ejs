<% layout("/layout/boilerplate")%>


    <form method="POST" novalidate class="needs-validation" action="/listings/<%=listing.id%>?_method=PUT"
        enctype="multipart/form-data">
        <div class="row mt-3">
            <div class="col-8 offset-2">
                <h3>Now you can edit your post</h3>
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="listing[title]" value="<%=listing.title%>" id="" class="form-control"
                        required>
                    <div class="invalid-feedback">Write a title!</div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description:</label>
                    <textarea name="listing[description]" class="form-control"
                        required><%=listing.description%></textarea>
                    <div class="invalid-feedback">Write a short description</div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price:</label>
                        <input type="number" id="price" name="listing[price]" required value="<%=listing.price%>"
                            class="form-control">
                        <div class="invalid-feedback">Enter a valid price</div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="Country" class="form-label">Country:</label>
                        <input type="text" name="listing[country]" required value="<%=listing.country%>"
                            class="form-control">
                        <div class="invalid-feedback">Enter a valid country</div>
                    </div>
                    <div class="mb-3 col-md-8">
                        <label class="form-label">Category:</label>
                        <input type="hidden" name="listing[category]" id="categoryInput" value="<%= listing.category %>"
                            required>
                        <div class="custom-select-wrapper">
                            <div class="custom-select" id="categorySelect">
                                <span class="selected-text">
                                    <%= listing.category || 'Select a category' %>
                                </span>
                                <i class="fas fa-chevron-down arrow"></i>
                            </div>
                            <div class="custom-options" id="categoryOptions">
                                <% for(let cat of category) { %>
                                    <div class="custom-option <%= listing.category === cat ? 'selected' : '' %>"
                                        data-value="<%= cat %>">
                                        <i class="fas fa-check check-icon"></i>
                                        <%= cat %>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                        <div class="invalid-feedback">Please select a category</div>
                    </div>
                </div>
                <div class="mb-3">
                    <p>Original Image</p>
                    <img src="<%=originalImage%>" class="img-fluid rounded" alt="listing_image"
                        style="width: 250px; height: 150px; object-fit: cover;">
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image link:</label>
                    <input type="file" value="<%=listing.image.url%>" name="listing[image]" id="" class="form-control">
                </div>
                <div>
                    <label for="loaction" class="form-label">Loaction:</label>
                    <input type="text" name="listing[location]" required value="<%=listing.location%>"
                        class="form-control">
                    <div class="invalid-feedback">Enter a valid location</div>
                </div>
                <button class="btn btn-dark edit-btn mt-2">Edit</button>
            </div>
        </div>
    </form>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const selectBox = document.getElementById('categorySelect');
            const optionsBox = document.getElementById('categoryOptions');
            const hiddenInput = document.getElementById('categoryInput');
            const selectedText = selectBox.querySelector('.selected-text');
            const options = document.querySelectorAll('.custom-option');

            if (selectBox && optionsBox) {
                // Toggle dropdown
                selectBox.addEventListener('click', function (e) {
                    e.stopPropagation();
                    selectBox.classList.toggle('active');
                    optionsBox.classList.toggle('show');
                });

                // Select option
                options.forEach(option => {
                    option.addEventListener('click', function () {
                        const value = this.dataset.value;

                        // Update hidden input
                        hiddenInput.value = value;

                        // Update selected text
                        selectedText.textContent = value;

                        // Update selected state
                        options.forEach(opt => opt.classList.remove('selected'));
                        this.classList.add('selected');

                        // Close dropdown
                        selectBox.classList.remove('active');
                        optionsBox.classList.remove('show');
                    });
                });

                // Close on outside click
                document.addEventListener('click', function () {
                    selectBox.classList.remove('active');
                    optionsBox.classList.remove('show');
                });
            }
        });
    </script>
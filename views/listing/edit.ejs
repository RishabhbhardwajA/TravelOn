<% layout("/layout/boilerplate")%>

    
    <form method="POST" novalidate class="needs-validation" action="/listings/<%=details.id%>?_method=PUT">
        <div class="row mt-3">
            <div class="col-8 offset-2">
                <h3>Now you can edit your post</h3>
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="listing[title]" value="<%=details.title%>" id="" class="form-control" required>
                    <div class="invalid-feedback">Write a title!</div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description:</label>
                    <textarea name="listing[description]" class="form-control"  required><%=details.description%></textarea>
                    <div class="invalid-feedback">Write a short description</div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price:</label>
                        <input type="number" id="price" name="listing[price]"  required value="<%=details.price%>" class="form-control">
                        <div class="invalid-feedback">Enter a valid price</div> 
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="Country" class="form-label">Country:</label>
                        <input type="text" name="listing[country]"  required value="<%=details.country%>" class="form-control">
                        <div class="invalid-feedback">Enter a valid country</div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="image" class="form-label">Image link:</label>
                    <input type="text" value="<%=details.image.url%>"  required name="listing[image]" id="" class="form-control">
                </div>
                <div>
                    <label for="loaction" class="form-label">Loaction:</label>
                    <input type="text" name="listing[location]"  required value="<%=details.location%>" class="form-control">
                     <div class="invalid-feedback">Enter a valid location</div>
                </div>
                <button class="btn btn-dark edit-btn mt-2">Edit</button>
            </div>
        </div>
    </form>
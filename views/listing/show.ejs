<% layout("/layout/boilerplate")%>

    <div class="row mt-4">
        <div class="col-8 offset-3">
            <h3>
                <%=listing.title%>
            </h3>
        </div>
        <div class="card liting-card offset-3 col-6">
            <img src="<%=listing.image.url%>" class="card-img-top show-image" alt="listing_image">
            <div class="card-body">
                <p class="card-text"><b>
                        <i>
                            <%=listing.owner.username%>
                        </i><br>
                        <%=listing.description%> <br>
                            &#8377;<%=listing.price.toLocaleString("en-IN" )%> <br>
                                <%=listing.location%> <br>
                                    <%=listing.country%> <br>
                </p>
            </div>
        </div>
        <%if(currUser && currUser._id.equals(listing.owner._id)){%>
            <div class="btns mt-3 mb-3">
                <a href="/listings/<%=listing.id%>/edit" class="btn btn-dark col-1 offset-3 add-btn">Edit</a><br>
                <form method="POST" action="/listings/<%=listing.id%>?_method=DELETE"><button
                        class="btn btn-dark offset-2">DELETE</button></form>
            </div>
            <%}%>

                <div class="offset-3 col-6 mb-3 mt-3">


                    <%if(currUser){%>
                        <hr>
                        <h4>Leave a review</h4>
                        <form action="/listings/<%=listing.id%>/review" method="POST" novalidate
                            class="needs-validation">
                            <div class="mt-3 mb-3">
                                <label for="rating">Rating</label>
                                <fieldset class="starability-coinFlip">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                        value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>
                            <div class="mt-3 mb-3">
                                <label for="Comment">Comment</label>
                                <textarea name="review[comment]" id="Comment" col="30" rows="5" required
                                    class="form-control"></textarea>
                                <div class="invalid-feedback">Please add some review</div>
                            </div>
                            <button class="btn btn-outline-dark">Submit</button>
                        </form>
                        <%}%>

                            <% if(listing.review.length>0){%>
                                <h4>All reviews</h4>
                                <div class="row ">
                                    <hr>
                                    <% for(let review of listing.review){%>
                                        <div class="card col-5 ms-2 mb-3">
                                            <div class="card-body">
                                                <h5 class="card-title">@<%=review.author.username%>
                                                </h5>
                                                <p class="card-text">
                                                    <%=review.comment%>
                                                </p>
                                                </p>
                                                <p class="starability-result card-text"
                                                    data-rating="<%=review.rating%>"></p>

                                            </div>
                                            <form method="POST"
                                                action="/listings/<%= listing._id %>/review/<%= review._id %>?_method=DELETE">
                                                <button class="btn btn-dark btn-sm mb-2 ms-2">Delete</button>
                                            </form>

                                        </div>
                                        <%}%>
                                </div>
                                <%}%>
                </div>
                <div class="col-8 offset-3 mb-3 map">
                    <h3>Where you'll be</h3>
                    <div id="map" ></div>
                </div>

    </div>
<script>
    const listing = <%- JSON.stringify(listing) %>;
</script>

<script src="/js/map.js"></script>